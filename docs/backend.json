
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Маълумоти асосии корбар ва ҳолати верификатсия",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Usto", "Client"] },
        "phone": { "type": "string" },
        "region": { "type": "string" },
        "balance": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "identificationStatus": { "type": "string", "enum": ["None", "Pending", "Verified", "Rejected", "Blocked"] }
      }
    },
    "PremiumRequest": {
      "title": "PremiumRequest",
      "description": "Дархост барои хариди статуси Premium тавассути чек",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "receiptImage": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    },
    "VerificationRequest": {
      "title": "VerificationRequest",
      "description": "Дархост барои тасдиқи шахсият",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "receipt": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Профилҳои асосии корбарон"
    },
    "/premium_requests/{userId}": {
      "schema": "PremiumRequest",
      "description": "Дархостҳои хариди Premium"
    },
    "/verification_requests/{userId}": {
      "schema": "VerificationRequest",
      "description": "Дархостҳои верификатсияи паспорт"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Эълонҳои ҳунармандон"
    }
  }
}
